# === Server ===
PORT=4000
CORS_ORIGIN=http://localhost:5173

# === Database (PostgreSQL) ===
DATABASE_URL=postgresql://user:password@localhost:5432/focustimer

# === JWT (REQUIRED - server will not start without these) ===
JWT_SECRET=replace-with-a-strong-random-secret
JWT_REFRESH_SECRET=replace-with-another-strong-random-secret

# === Sentry (Phase 2, optional) ===
# VITE_SENTRY_DSN=

# === Resend Email (Phase 3, optional) ===
# RESEND_API_KEY=
